# Documented env vars — NEVER put real secrets here.
# Copy to .env (gitignored) for local overrides.

POSTGRES_USER=seatwise
POSTGRES_PASSWORD=seatwise
POSTGRES_DB=seatwise

# Per-service connection strings (override the in-code dev defaults).
ConnectionStrings__ordering=Host=localhost;Port=5432;Database=seatwise_ordering;Username=seatwise;Password=seatwise
ConnectionStrings__catalog=Host=localhost;Port=5432;Database=seatwise_catalog;Username=seatwise;Password=seatwise
ConnectionStrings__identity=Host=localhost;Port=5432;Database=seatwise_identity;Username=seatwise;Password=seatwise

# Messaging / cache (used from M5/M6 onward).
RABBITMQ__HOST=localhost
REDIS__CONNECTION=localhost:6379
