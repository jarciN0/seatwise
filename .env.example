# Optional local overrides. docker-compose.yml already sets these for the stack;
# you only need this file if you run the services with `dotnet run` by hand.
# Never put real secrets here.

# Booking service → Postgres
ConnectionStrings__postgres=Host=localhost;Port=5432;Database=seatwise;Username=seatwise;Password=seatwise

# Both services → RabbitMQ
RABBITMQ_URI=amqp://guest:guest@localhost:5672
